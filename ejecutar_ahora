package KuHub.modules.gestion_proveedor.repository;

import KuHub.modules.gestion_proveedor.entity.ProveedorProducto;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

import java.util.List;
import java.util.Optional;

@Repository
public interface ProveedorProductoRepository extends JpaRepository<ProveedorProducto, Integer> {

    // ─── 1. Métodos JPA derivados ────────────────────────────────────────────

    /** Verifica si ya existe la relación entre un proveedor y un producto. */
    boolean existsByProveedor_IdProveedorAndProducto_IdProducto(Integer idProveedor, Integer idProducto);

    /** Verifica si ya existe la relación entre un proveedor y un producto, excluyendo un ID. */
    boolean existsByProveedor_IdProveedorAndProducto_IdProductoAndIdProveedorProductoNot(
            Integer idProveedor, Integer idProducto, Integer idProveedorProducto);

    /** Busca una relación activa por su ID. */
    Optional<ProveedorProducto> findByIdProveedorProductoAndActivoTrue(Integer idProveedorProducto);

    // ─── 2. @Query personalizados de solo lectura ────────────────────────────

    /**
     * Lista todos los productos activos asociados a un proveedor activo.
     * Columnas: [0] id_proveedor_producto, [1] id_producto, [2] nombre_producto,
     *           [3] cod_producto, [4] nombre_categoria, [5] nombre_unidad,
     *           [6] abreviatura, [7] precio, [8] activo
     */
    @Query(value = """
            SELECT
                pp.id_proveedor_producto,   -- [0]
                pr.id_producto,             -- [1]
                pr.nombre_producto,         -- [2]
                pr.cod_producto,            -- [3]
                c.nombre_categoria,         -- [4]
                u.nombre_unidad,            -- [5]
                u.abreviatura,              -- [6]
                pp.precio,                  -- [7]
                pp.activo                   -- [8]
            FROM proveedor_producto pp
            INNER JOIN producto pr ON pr.id_producto = pp.id_producto
            INNER JOIN categoria c ON c.id_categoria = pr.id_categoria
            INNER JOIN unidad_medida u ON u.id_unidad = pr.id_unidad
            WHERE pp.id_proveedor = :idProveedor
              AND pr.activo = TRUE
            ORDER BY pr.nombre_producto ASC
            """, nativeQuery = true)
    List<Object[]> findProductosByProveedorRaw(@Param("idProveedor") Integer idProveedor);

    // ─── 3. @Modifying + @Transactional ─────────────────────────────────────

    /** Actualiza el estado activo de una relación proveedor-producto por su ID. */
    @Modifying
    @Query("UPDATE ProveedorProducto pp SET pp.activo = :activo WHERE pp.idProveedorProducto = :id")
    int updateActivoById(@Param("id") Integer id, @Param("activo") Boolean activo);
}
