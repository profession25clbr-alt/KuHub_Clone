package KuHub.modules.gestion_proveedor.service;

import KuHub.modules.gestion_proveedor.dtos.request.*;
import KuHub.modules.gestion_proveedor.dtos.response.ProductoConPrecioDTO;
import KuHub.modules.gestion_proveedor.dtos.response.ProveedorDetalleDTO;
import KuHub.modules.gestion_proveedor.dtos.response.ProveedorListDTO;
import KuHub.modules.gestion_proveedor.entity.Proveedor;
import KuHub.modules.gestion_proveedor.entity.ProveedorProducto;
import KuHub.modules.gestion_proveedor.enums.EstadoProveedor;
import KuHub.modules.gestion_proveedor.exceptions.GestionProveedorException;
import KuHub.modules.gestion_proveedor.repository.ProveedorProductoRepository;
import KuHub.modules.gestion_proveedor.repository.ProveedorRepository;
import KuHub.utils.StringUtils;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.HttpStatus;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;

@Slf4j
@Service
@RequiredArgsConstructor
public class ProveedorServiceImpl implements ProveedorService {

    /**Repositories*/
    @Autowired
    private ProveedorRepository proveedorRepository;

    @Autowired
    private ProveedorProductoRepository proveedorProductoRepository;

    // ─── Métodos de búsqueda ─────────────────────────────────────────────────

    @Override
    @Transactional(readOnly = true)
    public List<ProveedorListDTO.ProveedorItem> findAllProveedores() {
        List<Object[]> rows = proveedorRepository.findAllActiveProveedoresRaw();
        return rows.stream()
                .map(ProveedorListDTO.ProveedorItem::fromRow)
                .toList();
    }

    @Override
    @Transactional(readOnly = true)
    public ProveedorDetalleDTO findProveedorById(Integer idProveedor) {
        Object[] base = proveedorRepository.findProveedorDetalleBaseRaw(idProveedor)
                .orElseThrow(() -> new GestionProveedorException(
                        "Proveedor no encontrado con ID: " + idProveedor,
                        HttpStatus.NOT_FOUND));

        List<Object[]> productosRows = proveedorProductoRepository.findProductosByProveedorRaw(idProveedor);
        List<ProductoConPrecioDTO> productos = productosRows.stream()
                .map(ProductoConPrecioDTO::fromRow)
                .toList();

        return ProveedorDetalleDTO.fromRow(base, productos);
    }

    // ─── Métodos de creación ─────────────────────────────────────────────────

    @Override
    @Transactional
    public Boolean saveProveedor(ProveedorCreateDTO request) {
        if (proveedorRepository.existsByRutProveedor(request.getRutProveedor())) {
            throw new GestionProveedorException(
                    "Ya existe un proveedor con el RUT: " + request.getRutProveedor(),
                    HttpStatus.CONFLICT);
        }
        if (proveedorRepository.existsByEmailProveedor(request.getEmailProveedor())) {
            throw new GestionProveedorException(
                    "Ya existe un proveedor con el email: " + request.getEmailProveedor(),
                    HttpStatus.CONFLICT);
        }

        Proveedor proveedor = new Proveedor();
        proveedor.setNombreProveedor(StringUtils.capitalizarPalabras(request.getNombreProveedor()));
        proveedor.setRutProveedor(request.getRutProveedor());
        proveedor.setEmailProveedor(request.getEmailProveedor().toLowerCase());
        proveedor.setTelefonoProveedor(request.getTelefonoProveedor());
        proveedor.setDireccionProveedor(request.getDireccionProveedor());
        proveedor.setEstadoProveedor(EstadoProveedor.DISPONIBLE);
        proveedor.setActivo(true);

        proveedorRepository.save(proveedor);
        log.info("Proveedor creado: {} | RUT: {}", proveedor.getNombreProveedor(), proveedor.getRutProveedor());
        return true;
    }

    // ─── Métodos de actualización ────────────────────────────────────────────

    @Override
    @Transactional
    public Boolean updateProveedor(ProveedorUpdateDTO request) {
        Proveedor proveedor = proveedorRepository.findByIdProveedorAndActivoTrue(request.getIdProveedor())
                .orElseThrow(() -> new GestionProveedorException(
                        "Proveedor no encontrado con ID: " + request.getIdProveedor(),
                        HttpStatus.NOT_FOUND));

        if (proveedorRepository.existsByRutProveedorAndIdProveedorNot(request.getRutProveedor(), request.getIdProveedor())) {
            throw new GestionProveedorException(
                    "Ya existe otro proveedor con el RUT: " + request.getRutProveedor(),
                    HttpStatus.CONFLICT);
        }
        if (proveedorRepository.existsByEmailProveedorAndIdProveedorNot(request.getEmailProveedor(), request.getIdProveedor())) {
            throw new GestionProveedorException(
                    "Ya existe otro proveedor con el email: " + request.getEmailProveedor(),
                    HttpStatus.CONFLICT);
        }

        String nuevoNombre = StringUtils.capitalizarPalabras(request.getNombreProveedor());
        if (!proveedor.getNombreProveedor().equals(nuevoNombre)) {
            proveedor.setNombreProveedor(nuevoNombre);
        }
        if (!proveedor.getRutProveedor().equals(request.getRutProveedor())) {
            proveedor.setRutProveedor(request.getRutProveedor());
        }
        if (!proveedor.getEmailProveedor().equals(request.getEmailProveedor().toLowerCase())) {
            proveedor.setEmailProveedor(request.getEmailProveedor().toLowerCase());
        }
        if (request.getTelefonoProveedor() != null &&
                !request.getTelefonoProveedor().equals(proveedor.getTelefonoProveedor())) {
            proveedor.setTelefonoProveedor(request.getTelefonoProveedor());
        }
        if (request.getDireccionProveedor() != null &&
                !request.getDireccionProveedor().equals(proveedor.getDireccionProveedor())) {
            proveedor.setDireccionProveedor(request.getDireccionProveedor());
        }

        EstadoProveedor nuevoEstado = EstadoProveedor.valueOf(request.getEstadoProveedor());
        if (!proveedor.getEstadoProveedor().equals(nuevoEstado)) {
            proveedor.setEstadoProveedor(nuevoEstado);
        }

        proveedorRepository.save(proveedor);
        log.info("Proveedor actualizado: ID={} | Nombre={}", proveedor.getIdProveedor(), proveedor.getNombreProveedor());
        return true;
    }

    @Override
    @Transactional
    public Boolean addProductoToProveedor(ProveedorProductoAddDTO request) {
        if (!proveedorRepository.findByIdProveedorAndActivoTrue(request.getIdProveedor()).isPresent()) {
            throw new GestionProveedorException(
                    "Proveedor no encontrado con ID: " + request.getIdProveedor(),
                    HttpStatus.NOT_FOUND);
        }
        if (proveedorProductoRepository.existsByProveedor_IdProveedorAndProducto_IdProducto(
                request.getIdProveedor(), request.getIdProducto())) {
            throw new GestionProveedorException(
                    "El producto ya está asociado a este proveedor.",
                    HttpStatus.CONFLICT);
        }

        ProveedorProducto pp = new ProveedorProducto();
        pp.setIdProveedor(request.getIdProveedor());
        pp.setIdProducto(request.getIdProducto());
        pp.setPrecio(request.getPrecio());
        pp.setActivo(true);

        proveedorProductoRepository.save(pp);
        log.info("Producto ID={} agregado al proveedor ID={} con precio={}",
                request.getIdProducto(), request.getIdProveedor(), request.getPrecio());
        return true;
    }

    @Override
    @Transactional
    public Boolean updatePrecioProducto(ProveedorProductoUpdateDTO request) {
        ProveedorProducto pp = proveedorProductoRepository
                .findByIdProveedorProductoAndActivoTrue(request.getIdProveedorProducto())
                .orElseThrow(() -> new GestionProveedorException(
                        "Relación proveedor-producto no encontrada con ID: " + request.getIdProveedorProducto(),
                        HttpStatus.NOT_FOUND));

        if (!pp.getPrecio().equals(request.getPrecio())) {
            pp.setPrecio(request.getPrecio());
        }

        proveedorProductoRepository.save(pp);
        log.info("Precio actualizado para proveedor-producto ID={} | Nuevo precio={}",
                pp.getIdProveedorProducto(), pp.getPrecio());
        return true;
    }

    // ─── Métodos de eliminación lógica ───────────────────────────────────────

    @Override
    @Transactional
    public Boolean softDeleteProveedor(Integer idProveedor) {
        Proveedor proveedor = proveedorRepository.findByIdProveedorAndActivoTrue(idProveedor)
                .orElseThrow(() -> new GestionProveedorException(
                        "Proveedor no encontrado con ID: " + idProveedor,
                        HttpStatus.NOT_FOUND));

        proveedor.setActivo(false);
        proveedorRepository.save(proveedor);
        log.info("Proveedor eliminado lógicamente: ID={} | Nombre={}", idProveedor, proveedor.getNombreProveedor());
        return true;
    }

    @Override
    @Transactional
    public Boolean softDeleteProveedorProducto(Integer idProveedorProducto) {
        ProveedorProducto pp = proveedorProductoRepository
                .findByIdProveedorProductoAndActivoTrue(idProveedorProducto)
                .orElseThrow(() -> new GestionProveedorException(
                        "Relación proveedor-producto no encontrada con ID: " + idProveedorProducto,
                        HttpStatus.NOT_FOUND));

        pp.setActivo(false);
        proveedorProductoRepository.save(pp);
        log.info("Relación proveedor-producto eliminada lógicamente: ID={}", idProveedorProducto);
        return true;
    }
}
