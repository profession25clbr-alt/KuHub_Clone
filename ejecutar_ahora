package KuHub.modules.gestion_proveedor.repository;

import KuHub.modules.gestion_proveedor.entity.Proveedor;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

import java.util.List;
import java.util.Optional;

@Repository
public interface ProveedorRepository extends JpaRepository<Proveedor, Integer> {

    // ─── 1. Métodos JPA derivados ────────────────────────────────────────────

    /** Busca un proveedor activo por su ID. */
    Optional<Proveedor> findByIdProveedorAndActivoTrue(Integer idProveedor);

    /** Verifica si existe un proveedor con el RUT dado (sin importar estado activo). */
    boolean existsByRutProveedor(String rutProveedor);

    /** Verifica si existe un proveedor con el email dado (sin importar estado activo). */
    boolean existsByEmailProveedor(String emailProveedor);

    /** Verifica si existe otro proveedor con el mismo RUT, excluyendo el ID indicado. */
    boolean existsByRutProveedorAndIdProveedorNot(String rutProveedor, Integer idProveedor);

    /** Verifica si existe otro proveedor con el mismo email, excluyendo el ID indicado. */
    boolean existsByEmailProveedorAndIdProveedorNot(String emailProveedor, Integer idProveedor);

    // ─── 2. @Query personalizados de solo lectura ────────────────────────────

    /**
     * Lista todos los proveedores activos con la cantidad de productos activos asociados.
     * Columnas: [0] id_proveedor, [1] nombre_proveedor, [2] rut_proveedor,
     *           [3] email_proveedor, [4] telefono_proveedor, [5] estado_proveedor,
     *           [6] cantidad_productos
     */
    @Query(value = """
            SELECT
                p.id_proveedor,          -- [0]
                p.nombre_proveedor,      -- [1]
                p.rut_proveedor,         -- [2]
                p.email_proveedor,       -- [3]
                p.telefono_proveedor,    -- [4]
                p.estado_proveedor,      -- [5]
                COUNT(pp.id_proveedor_producto) AS cantidad_productos  -- [6]
            FROM proveedor p
            LEFT JOIN proveedor_producto pp
                   ON pp.id_proveedor = p.id_proveedor
                  AND pp.activo = TRUE
            WHERE p.activo = TRUE
            GROUP BY p.id_proveedor, p.nombre_proveedor, p.rut_proveedor,
                     p.email_proveedor, p.telefono_proveedor, p.estado_proveedor
            ORDER BY p.nombre_proveedor ASC
            """, nativeQuery = true)
    List<Object[]> findAllActiveProveedoresRaw();

    /**
     * Obtiene los datos base de un proveedor activo por su ID.
     * Columnas: [0] id_proveedor, [1] nombre_proveedor, [2] rut_proveedor,
     *           [3] email_proveedor, [4] telefono_proveedor, [5] direccion_proveedor,
     *           [6] estado_proveedor
     */
    @Query(value = """
            SELECT
                p.id_proveedor,          -- [0]
                p.nombre_proveedor,      -- [1]
                p.rut_proveedor,         -- [2]
                p.email_proveedor,       -- [3]
                p.telefono_proveedor,    -- [4]
                p.direccion_proveedor,   -- [5]
                p.estado_proveedor       -- [6]
            FROM proveedor p
            WHERE p.id_proveedor = :idProveedor
              AND p.activo = TRUE
            """, nativeQuery = true)
    Optional<Object[]> findProveedorDetalleBaseRaw(@Param("idProveedor") Integer idProveedor);

    // ─── 3. @Modifying + @Transactional ─────────────────────────────────────

    /** Actualiza el estado activo de un proveedor por su ID. */
    @Modifying
    @Query("UPDATE Proveedor p SET p.activo = :activo WHERE p.idProveedor = :idProveedor")
    int updateActivoById(@Param("idProveedor") Integer idProveedor, @Param("activo") Boolean activo);
}
