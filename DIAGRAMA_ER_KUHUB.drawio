        <mxCell id="config_note" value="&lt;b&gt;TABLAS COMPLEMENTARIAS&lt;/b&gt;&lt;br/&gt;• gestion_sistema: Configuración global&lt;br/&gt;• semanas: Períodos académicos&lt;br/&gt;• refresh_token: JWT tokens&lt;br/&gt;• docente_seccion: Asignación docentes (M:M)&lt;br/&gt;• asignatura_profesor_cargo: Profesor a cargo (M:M)&lt;br/&gt;• modulo, permiso_rol: Sistema de permisos" style="text;html=1;fontSize=10;align=left;fillColor=#e8f4f8;strokeColor=#0077d8;rounded=1;whiteSpace=wrap;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="650" y="1000" width="280" height="120" as="geometry" />
        </mxCell>

        <!-- NOTA SOBRE SOLICITUDES Y PEDIDOS -->
        <mxCell id="solicitud_note" value="&lt;b&gt;MÓDULOS DE SOLICITUDES/PEDIDOS&lt;/b&gt;&lt;br/&gt;(Ver documento DIAGRAMA_ER_KUHUB.md)&lt;br/&gt;• solicitud: Solicitudes de insumos&lt;br/&gt;• detalle_solicitud: Items de solicitud&lt;br/&gt;• pedido: Pedidos operativos&lt;br/&gt;• detalle_pedido: Items de pedido&lt;br/&gt;• pedido_solicitud: M:M solicitud-pedido&lt;br/&gt;• pedido_semana_bodega: Recetas/plantillas" style="text;html=1;fontSize=10;align=left;fillColor=#f0e6f0;strokeColor=#9933ff;rounded=1;whiteSpace=wrap;overflow=hidden;" vertex="1" parent="1">
